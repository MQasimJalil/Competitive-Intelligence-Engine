APP_NAME="business_tools"
APP_ENV="development"
APP_BASE_URL="http://127.0.0.1:8000"
DEPLOY_SHA=""
BUILD_TIMESTAMP=""
CRAWLER_USER_AGENT="CompetitorBriefBot/0.1 (+mailto:owner@example.com)"
CRAWL_TIMEOUT_SECONDS="12"
CRAWL_MAX_PAGES_PER_DOMAIN="12"
CRAWL_MAX_RESPONSE_BYTES="5000000"
CRAWL_MAX_REDIRECTS="5"
CRAWL_MAX_SITEMAP_URLS="500"
CRAWL_SELECTION_LIMIT="5"
CRAWL_CONCURRENCY="3"
ROBOTS_MAX_RESPONSE_BYTES="250000"
RENDERED_BROWSER_ENABLED="false"
RENDERED_BROWSER_CHANNEL="chrome"
RENDERED_BROWSER_TIMEOUT_SECONDS="20"
# OpenRouter is the default provider. OPENAI_API_KEY/OPENAI_MODEL remain supported
# as backwards-compatible fallbacks.
AI_PROVIDER="openrouter"
AI_ANALYSIS_ENGINE="openai"
AI_API_KEY=""
# Alternatively, set OPENROUTER_API_KEY instead of AI_API_KEY.
OPENROUTER_API_KEY=""
AI_BASE_URL="https://openrouter.ai/api/v1"
AI_MODEL="openai/gpt-5.4"
AI_HTTP_REFERER="http://127.0.0.1:8000"
AI_APP_TITLE="Competitor Brief"
OPENAI_API_KEY=""
OPENAI_MODEL=""
AI_ANALYSIS_ENABLED="true"
AI_PROMPT_VERSION="competitor-brief-v1"
AI_SCHEMA_VERSION="analysis-v1"
AI_CACHE_ENABLED="true"
AI_CACHE_DIR="var/ai_cache"
AI_RUN_LOG_PATH="var/logs/ai_runs.jsonl"
RUNTIME_SETTINGS_PATH="var/runtime_settings.json"
AI_MAX_INPUT_TOKENS="12000"
AI_MAX_OUTPUT_TOKENS="2000"
REPORT_MAX_COST_USD="0.15"
AI_MAX_COST_USD="0.075"
# Set these from the current model pricing page to enable cost estimates and preflight limits.
AI_INPUT_COST_PER_MILLION="0"
AI_OUTPUT_COST_PER_MILLION="0"
JOB_STORE_DIR="var/jobs"
POSTGRES_PASSWORD="replace-with-a-long-random-password"
JOB_REPOSITORY="postgres"
# Docker Compose backend defaults to @postgres:5432 internally. Use this
# only when running the FastAPI backend directly on the host.
DATABASE_URL="postgresql://competitor:replace-with-a-long-random-password@127.0.0.1:54329/competitor_brief"
# Optional Compose override. Usually leave blank for local Docker.
COMPOSE_DATABASE_URL=""
POSTGRES_POOL_MAX_SIZE="8"
LOCAL_OWNER_ID="local-development-user"
USER_STORE_DIR="var/users"
USER_REPOSITORY="postgres"
AUTH_PROVIDER="local"
SUPABASE_URL="https://kacanssleoyrhnujavxc.supabase.co"
SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_JWT_SECRET=""
SUPABASE_DB_URL="postgresql://postgres:[YOUR-PASSWORD]@db.kacanssleoyrhnujavxc.supabase.co:5432/postgres"
SIGNUP_FREE_CREDITS="2"
BETA_STARTING_CREDITS="0"
CAPTCHA_SITE_KEY=""
